generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("EMPLOYEE")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  auditLogs AuditLog[]
}

model Item {
  id          Int          @id @default(autoincrement())
  reference   String       @unique
  name        String
  model       String?
  type        String
  size        String
  color       String
  status      String       @default("AVAILABLE")
  statusRemarks String?
  rentalPrice Float        @default(0)
  quantity    Int          @default(1)
  ensembleId  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  rentals     RentalItem[]

  @@index([status])
  @@index([type])
  @@index([ensembleId])
}

model Customer {
  id            Int      @id @default(autoincrement())
  firstName     String
  lastName      String
  phone         String
  address       String
  email         String?
  idNumber      String   @unique
  isBlacklisted Boolean  @default(false)
  createdAt     DateTime @default(now())
  rentals       Rental[]

  @@index([phone])
}

model Rental {
  id                Int            @id @default(autoincrement())
  customerId        Int
  startDate         DateTime       @default(now())
  expectedReturn    DateTime
  actualReturn      DateTime?
  totalAmount       Float          @default(0)
  depositAmount     Float          @default(0)
  paidAmount        Float          @default(0)
  discount          Float          @default(0)
  addedAmount       Float          @default(0)
  remarks           String?
  status            String         @default("ONGOING")
  isActivated       Boolean        @default(false)
  guaranteeDocument String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  cashMovements     CashMovement[]
  payments          Payment[]
  customer          Customer       @relation(fields: [customerId], references: [id])
  items             RentalItem[]

  @@index([startDate, expectedReturn])
  @@index([status])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model Payment {
  id        Int      @id @default(autoincrement())
  amount    Float
  rentalId  Int
  createdAt DateTime @default(now())
  rental    Rental   @relation(fields: [rentalId], references: [id])

  @@index([createdAt])
}

model CashMovement {
  id          Int      @id @default(autoincrement())
  rentalId    Int
  amount      Float
  type        String
  description String?
  date        DateTime
  createdAt   DateTime @default(now())
  rental      Rental   @relation(fields: [rentalId], references: [id])

  @@index([date])
}

model RentalItem {
  id                 Int     @id @default(autoincrement())
  rentalId           Int
  itemId             Int
  remarks            String?
  tailorModification String?
  item               Item    @relation(fields: [itemId], references: [id])
  rental             Rental  @relation(fields: [rentalId], references: [id])
}

model DailyCash {
  id            Int      @id @default(autoincrement())
  date          DateTime @unique @default(now())
  initialCash   Float    @default(0)
  totalRentals  Float    @default(0)
  totalExpenses Float    @default(0)
  finalBalance  Float    @default(0)
  status        String   @default("OPEN")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
}

model Withdrawal {
  id          Int      @id @default(autoincrement())
  amount      Float
  description String?
  date        DateTime @default(now())
  performedBy String
  createdAt   DateTime @default(now())

  @@index([date])
}

model Expense {
  id          Int      @id @default(autoincrement())
  amount      Float
  description String
  date        DateTime @default(now())
  slipNumber  String?
  performedBy String?
  createdAt   DateTime @default(now())

  @@index([date])
}

model Sale {
  id            Int        @id @default(autoincrement())
  customerName  String
  customerPhone String
  totalAmount   Float      @default(0)
  remarks       String?
  performedBy   String
  createdAt     DateTime   @default(now())
  items         SaleItem[]

  @@index([createdAt])
}

model SaleItem {
  id        Int    @id @default(autoincrement())
  saleId    Int
  itemRef   String
  itemName  String
  itemType  String
  itemSize  String
  itemColor String
  price     Float
  sale      Sale   @relation(fields: [saleId], references: [id])
}
