generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("EMPLOYEE")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  auditLogs AuditLog[]
}

model Item {
  id          Int          @id @default(autoincrement())
  reference   String       @unique
  name        String
  model       String?
  type        String
  size        String
  color       String
  status      String       @default("AVAILABLE")
  statusRemarks String?
  rentalPrice Float        @default(0)
  quantity    Int          @default(1)
  ensembleId  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  rentals     RentalItem[]

  @@index([status])
  @@index([type])
  @@index([ensembleId])
}

model Customer {
  id            Int      @id @default(autoincrement())
  firstName     String
  lastName      String
  phone         String
  address       String
  email         String?
  idNumber      String   @unique
  isBlacklisted Boolean  @default(false)
  createdAt     DateTime @default(now())
  rentals       Rental[]

  @@index([phone])
}

model Rental {
  id                Int            @id @default(autoincrement())
  customerId        Int
  startDate         DateTime       @default(now())
  expectedReturn    DateTime
  actualReturn      DateTime?
  totalAmount       Float          @default(0)
  depositAmount     Float          @default(0)
  paidAmount        Float          @default(0)
  discount          Float          @default(0)
  addedAmount       Float          @default(0)
  remarks           String?
  status            String         @default("ONGOING")
  isActivated       Boolean        @default(false)
  guaranteeDocument String?
  repairFees        Float          @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  cashMovements     CashMovement[]
  payments          Payment[]
  customer          Customer       @relation(fields: [customerId], references: [id])
  items             RentalItem[]

  @@index([startDate, expectedReturn])
  @@index([status])
  @@index([customerId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  action    String
  details   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Payment {
  id          Int      @id @default(autoincrement())
  amount      Float
  type        String   @default("ENCAISSEMENT_SOLDE")
  rentalId    Int
  performedBy String?
  createdAt   DateTime @default(now())
  rental      Rental   @relation(fields: [rentalId], references: [id])

  @@index([createdAt])
  @@index([rentalId])
}

model CashMovement {
  id          Int      @id @default(autoincrement())
  rentalId    Int
  amount      Float
  type        String
  description String?
  date        DateTime
  createdAt   DateTime @default(now())
  rental      Rental   @relation(fields: [rentalId], references: [id])

  @@index([date])
  @@index([rentalId])
}

model RentalItem {
  id                 Int     @id @default(autoincrement())
  rentalId           Int
  itemId             Int
  remarks            String?
  tailorModification String?
  item               Item    @relation(fields: [itemId], references: [id])
  rental             Rental  @relation(fields: [rentalId], references: [id])

  @@index([rentalId])
  @@index([itemId])
}

model DailyCash {
  id            Int      @id @default(autoincrement())
  date          DateTime @unique @default(now())
  initialCash   Float    @default(0)
  totalRentals     Float    @default(0)
  totalExpenses    Float    @default(0)
  totalWithdrawals Float    @default(0)
  finalBalance     Float    @default(0)
  status        String   @default("OPEN")
  totalPerfumeSales Float    @default(0)
  totalPerfumeProfit Float   @default(0)
  totalProductSales  Float    @default(0)
  totalProductProfit Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
}

model Withdrawal {
  id          Int      @id @default(autoincrement())
  amount      Float
  description String?
  date        DateTime @default(now())
  performedBy String
  createdAt   DateTime @default(now())

  @@index([date])
}

model Expense {
  id          Int      @id @default(autoincrement())
  amount      Float
  description String
  date        DateTime @default(now())
  slipNumber  String?
  performedBy String?
  createdAt   DateTime @default(now())

  @@index([date])
}

model Sale {
  id            Int        @id @default(autoincrement())
  customerName  String
  customerPhone String
  totalAmount   Float      @default(0)
  discount      Float      @default(0)
  remarks       String?
  performedBy   String
  createdAt     DateTime   @default(now())
  items         SaleItem[]

  @@index([createdAt])
}

model SaleItem {
  id        Int    @id @default(autoincrement())
  saleId    Int
  itemRef   String
  itemName  String
  itemType  String
  itemSize  String
  itemColor String
  price     Float
  sale      Sale   @relation(fields: [saleId], references: [id])

  @@index([saleId])
}

model Perfume {
  id                  Int           @id @default(autoincrement())
  brand               String
  name                String
  type                String?
  totalCapacityMl     Float
  initialQuantityMl   Float
  currentQuantityMl   Float
  totalPurchasePrice  Float
  unitCostMl          Float
  salePriceMl         Float
  alertThresholdMl    Float         @default(30)
  isActive            Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  sales               PerfumeSale[]
}

model PerfumeSale {
  id              Int      @id @default(autoincrement())
  perfumeId       Int
  quantityMl      Float
  unitPriceMl     Float
  totalAmount     Float
  totalCost       Float
  profit          Float
  discount        Float    @default(0)
  date            DateTime @default(now())
  performedBy     String
  perfume         Perfume  @relation(fields: [perfumeId], references: [id])

  @@index([date])
  @@index([perfumeId])
}

model Product {
  id            Int      @id @default(autoincrement())
  reference     String   @unique
  name          String
  type          String
  size          String
  color         String
  purchasePrice Float
  salePrice     Float
  quantity      Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  sales         ProductSale[]

  @@index([reference])
}

model ProductSale {
  id            Int      @id @default(autoincrement())
  productId     Int
  product       Product  @relation(fields: [productId], references: [id])
  quantity      Int
  unitPrice     Float
  totalAmount   Float
  totalCost     Float
  profit        Float
  discount      Float    @default(0)
  customerName  String?
  customerPhone String?
  performedBy   String
  date          DateTime @default(now())

  @@index([date])
  @@index([productId])
}
